# LLM API 配置
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat

# Vision 模型（图片题使用，为空则使用 LLM_MODEL）
LLM_VISION_MODEL=

# 最大 token 数（0 表示不限制）
LLM_MAX_TOKENS=0

# JSON 请求体大小限制
JSON_LIMIT=15mb

# 服务端口
PORT=3000

# 服务外网地址（油猴脚本回调用，填你的域名或公网 IP）
SERVER_BASE_URL=http://localhost:3000

# 允许的来源 (CORS)，多个用逗号分隔，* 表示允许所有
ALLOWED_ORIGINS=*
